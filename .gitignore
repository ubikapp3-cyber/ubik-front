##################################################
# 👷 PROYECTO UBIK-APP (.gitignore principal)
# Estructura: 
#   /backend        → microservicios Spring Boot
#   /frontend       → aplicación Angular
#   /microservicios → base común o submódulos
##################################################

############################
# 🔹 IntelliJ IDEA / JetBrains
############################
.idea/
*.iml
out/
*.ipr
*.iws
.ai/

############################
# 🔹 VSCode (si se usa)
############################
.vscode/

############################
# 🔹 Sistema operativo
############################
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

############################
# 🔹 Archivos temporales / logs
############################
logs/
*.log
*.tmp
*.bak
*.swp
*.swo

############################
# 🔹 Spring Boot / Maven / Gradle
############################
target/
build/
out/
.gradle/
.mvn/
!gradle/wrapper/gradle-wrapper.jar
!.mvn/wrapper/maven-wrapper.jar

spring.log
*.jar
*.war
*.ear
*.class

############################
# 🔹 Archivos de entorno o configuración sensible
############################
.env
.env.*
application-*.yml
application-*.properties
!application.yml
!application.properties

############################
# 🔹 Node.js / Angular (frontend)
############################
node_modules/
dist/
tmp/
.angular/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

############################
# 🔹 Archivos del sistema / editor
############################
*.orig
*.rej
*.sublime-workspace
*.sublime-project

############################
# 🔹 Archivos temporales y cache de IDEs
############################
*.idea_modules/
*.classpath
*.project
*.settings/

############################
# 🔹 Subcarpetas específicas del proyecto
############################
microservicios/.idea/
microservicios/**/target/
microservicios/**/build/
frontend/node_modules/
frontend/dist/
frontend/.angular/
backend/**/target/
backend/**/build/
backend/**/out/

############################
# 🔹 Otros
############################
*.pid
*.seed
*.pid.lock

./frontend/node_modules/
./frontend/.vscode/
./frontend/dist/
./frontend/build/
./frontend/.angular/
./frontend/.DS_Store


# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Compiled output
./frontend/dist
./frontend/tmp
./frontend/out-tsc
./frontend/bazel-out

# Node
./frontend/node_modules
./frontend/npm-debug.log
./frontend/yarn-error.log

# IDEs and editors
./frontend/.idea/
./frontend/.project
./frontend/.classpath
./frontend/.c9/
./frontend/*.launch
./frontend/.settings/
./frontend/*.sublime-workspace

# Visual Studio Code
./frontend/.vscode/*
./frontend/!.vscode/settings.json
./frontend/!.vscode/tasks.json
./frontend/!.vscode/launch.json
./frontend/!.vscode/extensions.json
./frontend/.history/*

# Miscellaneous
./frontend/.angular/cache
./frontend/.sass-cache/
./frontend/connect.lock
./frontend/coverage
./frontend/libpeerconnection.log
./frontend/testem.log
./frontend/typings
./frontend/__screenshots__/

# System files
./frontend/.DS_Store
./frontend/Thumbs.db
