# JWT Configuration
JWT_SECRET=your-secret-key-here-minimum-32-characters
JWT_EXPIRATION=86400000

# PostgreSQL Database Configuration
POSTGRES_DB=ubik_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password-here

# R2DBC Connection String for Services
# Format: r2dbc:postgresql://hostname:port/database
SPRING_R2DBC_URL=r2dbc:postgresql://postgres:5432/ubik_db
SPRING_R2DBC_USERNAME=postgres
SPRING_R2DBC_PASSWORD=your-password-here

# Alternative names for userManagement compatibility
# Note: userManagement uses DB_* naming instead of SPRING_R2DBC_*
# Both sets are required until userManagement is updated to standard naming
DB_R2DBC_URL=r2dbc:postgresql://postgres:5432/ubik_db
DB_USERNAME=postgres
DB_PASSWORD=your-password-here
