# JWT Configuration
JWT_SECRET=your-secret-key-here-minimum-32-characters
JWT_EXPIRATION=86400000

# PostgreSQL Database Configuration (for local docker container)
# These variables configure the PostgreSQL container created by docker-compose
POSTGRES_DB=ubik_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password-here

# R2DBC Connection String for Services
# Used by motel-management service
# Format: r2dbc:postgresql://hostname:port/database
#
# For LOCAL development with docker-compose PostgreSQL:
# SPRING_R2DBC_URL=r2dbc:postgresql://postgres:5432/ubik_db
# SPRING_R2DBC_USERNAME=postgres
# SPRING_R2DBC_PASSWORD=your-password-here
#
# For AZURE PostgreSQL Flexible Server:
SPRING_R2DBC_URL=r2dbc:postgresql://your-server.postgres.database.azure.com:5432/your-database?ssl=true
SPRING_R2DBC_USERNAME=your-admin-user
SPRING_R2DBC_PASSWORD=your-password

# Alternative names for userManagement compatibility
# Note: userManagement uses DB_* naming instead of SPRING_R2DBC_*
# Both sets are required until userManagement is updated to standard naming
#
# For LOCAL development with docker-compose PostgreSQL:
# DB_R2DBC_URL=r2dbc:postgresql://postgres:5432/ubik_db
# DB_USERNAME=postgres
# DB_PASSWORD=your-password-here
#
# For AZURE PostgreSQL Flexible Server:
DB_R2DBC_URL=r2dbc:postgresql://your-server.postgres.database.azure.com:5432/your-database?ssl=true
DB_USERNAME=your-admin-user
DB_PASSWORD=your-password
